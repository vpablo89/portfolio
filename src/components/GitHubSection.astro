---
interface Props {
  profileUrl: string
  username: string
}

const { profileUrl, username } = Astro.props
---

<article class="p-6 border rounded-2xl border-slate-200 bg-white/80 dark:border-slate-800 dark:bg-slate-900/60">
  <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">GitHub</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
    Repositorios organizados, actividad constante y proyectos con foco en backend, APIs y testing.
  </p>
  <div class="mt-5">
    <a
      href={profileUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex px-4 py-2 text-sm font-semibold transition border rounded-xl border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
    >
      Ver perfil de @{username}
    </a>
  </div>
</article>
