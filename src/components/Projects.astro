---
import type { PortfolioProject } from "@/types/project";

interface Props {
  projects: PortfolioProject[];
}

const { projects } = Astro.props;

const preferredUrls = [
  "https://github.com/vpablo89/padel-manager",
  "https://github.com/vpablo89/bookingsystem",
  "https://github.com/vpablo89/tournament-manager",
];

const preferredIndex = (url: string) => preferredUrls.indexOf(url);

const originalIndex = new Map(
  projects.map((project, index) => [project.githubUrl, index]),
);

const orderedProjects = projects.slice().sort((a, b) => {
  const pa = preferredIndex(a.githubUrl);
  const pb = preferredIndex(b.githubUrl);

  if (pa !== -1 || pb !== -1) {
    if (pa === -1) return 1;
    if (pb === -1) return -1;
    return pa - pb;
  }

  return (
    (originalIndex.get(a.githubUrl) ?? 0) -
    (originalIndex.get(b.githubUrl) ?? 0)
  );
});
---

<div id="projects-carousel" class="relative">
  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-slate-500 dark:text-slate-400">
      Desliza para ver mas proyectos
    </p>
    <div class="flex gap-2">
      <button
        type="button"
        data-prev
        class="hidden px-3 py-2 text-sm font-semibold transition border rounded-xl sm:inline-flex border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
        aria-label="Proyecto anterior"
      >
        Anterior
      </button>
      <button
        type="button"
        data-next
        class="hidden px-3 py-2 text-sm font-semibold transition border rounded-xl sm:inline-flex border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
        aria-label="Siguiente proyecto"
      >
        Siguiente
      </button>
    </div>
  </div>

  <div
    data-scroller
    class="flex gap-4 overflow-x-auto scroll-smooth pb-2 snap-x snap-mandatory [&::-webkit-scrollbar]:hidden"
  >
    {
      orderedProjects.map((project) => (
        <article
          data-slide
          class="snap-start w-full shrink-0 p-6 border rounded-2xl border-slate-200 bg-white/80 dark:border-slate-800 dark:bg-slate-900/60 sm:w-[48%] lg:w-[33.3333%]"
        >
          <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-100">
            {project.name}
          </h3>
          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">
            {project.description}
          </p>

          <div class="mt-4">
            <p class="text-xs font-semibold tracking-wide uppercase text-slate-500 dark:text-slate-400">
              Problema que resuelve
            </p>
            <p class="mt-1 text-sm text-slate-700 dark:text-slate-300">
              {project.problem}
            </p>
          </div>

          <div class="mt-4">
            <p class="text-xs font-semibold tracking-wide uppercase text-slate-500 dark:text-slate-400">
              Stack
            </p>
            <ul class="flex flex-wrap gap-2 mt-2">
              {project.stack.map((tech) => (
                <li class="px-2.5 py-1 text-xs rounded-full bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                  {tech}
                </li>
              ))}
            </ul>
          </div>

          <footer class="flex flex-wrap gap-3 mt-5">
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 text-sm font-semibold transition border rounded-xl border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
            >
              GitHub
            </a>
            {project.demoUrl && (
              <a
                href={project.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 text-sm font-semibold transition border rounded-xl border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
              >
                Demo
              </a>
            )}
            {project.docsUrl && (
              <a
                href={project.docsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 text-sm font-semibold transition border rounded-xl border-slate-300 text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
              >
                Postman Docs
              </a>
            )}
          </footer>
        </article>
      ))
    }
  </div>

  <script>
    (() => {
      const root = document.getElementById("projects-carousel");
      if (!root) return;

      const scroller = root.querySelector("[data-scroller]");
      const slides = Array.from(root.querySelectorAll("[data-slide]"));
      const prevBtn = root.querySelector(
        "[data-prev]",
      ) as HTMLButtonElement | null;
      const nextBtn = root.querySelector(
        "[data-next]",
      ) as HTMLButtonElement | null;

      if (!scroller || slides.length <= 1) return;

      let index = 0;

      const syncButtons = () => {
        if (prevBtn) prevBtn.disabled = index === 0;
        if (nextBtn) nextBtn.disabled = index === slides.length - 1;
      };

      const scrollToIndex = (nextIndex: number) => {
        index = Math.max(0, Math.min(slides.length - 1, nextIndex));
        slides[index].scrollIntoView({
          behavior: "smooth",
          inline: "start",
          block: "nearest",
        });
        syncButtons();
      };

      prevBtn?.addEventListener("click", () => scrollToIndex(index - 1));
      nextBtn?.addEventListener("click", () => scrollToIndex(index + 1));

      // Ajusta el índice cuando el usuario hace scroll manual.
      const onScroll = () => {
        const scrollerRect = scroller.getBoundingClientRect();
        const left = scrollerRect.left + 4;
        let best = 0;
        let bestDist = Number.POSITIVE_INFINITY;

        for (let i = 0; i < slides.length; i++) {
          const rect = slides[i].getBoundingClientRect();
          const dist = Math.abs(rect.left - left);
          if (dist < bestDist) {
            bestDist = dist;
            best = i;
          }
        }

        if (best !== index) {
          index = best;
          syncButtons();
        }
      };

      scroller.addEventListener("scroll", onScroll, { passive: true });
      syncButtons();
    })();
  </script>
</div>
